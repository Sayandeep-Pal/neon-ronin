# Neon Ronin — Game Client Environment (Example)
# Copy this file to .env and fill in your actual values.

# URL of the Express + Socket.io backend broker
# Local dev: http://localhost:3001
# Over devtunnels: https://xxxx-3001.asse.devtunnels.ms
VITE_BACKEND_URL=http://localhost:3001

# Base URL where the mobile controller client is hosted
# Local dev: http://localhost:5174
# Over devtunnels: https://xxxx-5174.asse.devtunnels.ms
VITE_CONTROLLER_URL=http://localhost:5174
